# ── Supabase (Required) ─────────────────────────────────
# From: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ── Payments / EFT (Required for payment features) ──────
BANK_NAME="First National Bank (FNB)"
BANK_ACCOUNT_NAME="LX Obsidian Labs"
BANK_ACCOUNT_NUMBER="628419273810"
BANK_BRANCH_CODE="255005"
PAYMENT_REFERENCE_PREFIX="RIV"

# ── Supabase Storage (Required for proof uploads) ───────
# The "payment-proofs" bucket will be auto-created on first upload
# if SERVICE_ROLE_KEY has storage admin permissions.

# ── AI Tutor (Optional) ─────────────────────────────────
# Get a free key at: https://build.nvidia.com/
NVIDIA_API_KEY="nvapi-..."
